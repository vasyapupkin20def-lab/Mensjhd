<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.5">
    <title>Календарь месячных · PRO</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: system-ui, 'Segoe UI', Roboto, sans-serif;
            margin: 0;
            padding: 0;
        }
        body {
            background: linear-gradient(145deg, #f6e2ea 0%, #f0ccd9 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .card {
            max-width: 780px;
            width: 100%;
            background: rgba(255, 247, 249, 0.9);
            backdrop-filter: blur(8px);
            background: #fef7f9;
            border-radius: 56px 56px 36px 36px;
            box-shadow: 0 30px 55px -14px rgba(100, 40, 60, 0.45), 0 8px 20px rgba(0,0,0,0.05);
            padding: 28px 24px 30px;
            border: 1px solid #ffdee8;
            transition: 0.2s;
        }
        h1 {
            font-size: 2.1rem;
            font-weight: 650;
            letter-spacing: -0.5px;
            color: #6e3349;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 6px;
            padding-bottom: 6px;
            border-bottom: 2px dashed #f0c4d0;
        }
        h1 small {
            font-size: 0.95rem;
            font-weight: 400;
            color: #a05f72;
            margin-left: auto;
            background: #fce4ec;
            padding: 4px 16px;
            border-radius: 40px;
        }
        .top-bar {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
            gap: 12px 10px;
            margin: 14px 0 16px;
            background: #ffedf2;
            padding: 12px 20px;
            border-radius: 80px;
            border: 1px solid #ffd6e2;
        }
        .top-bar label {
            display: flex;
            align-items: center;
            gap: 6px;
            font-weight: 500;
            color: #5c3344;
            font-size: 0.9rem;
        }
        .top-bar input[type="date"] {
            background: white;
            border: 1px solid #dbaebd;
            border-radius: 40px;
            padding: 6px 14px;
            font-size: 0.9rem;
            color: #2d1b22;
            outline: none;
            transition: 0.2s;
        }
        .top-bar input[type="date"]:focus {
            border-color: #b35f7a;
            box-shadow: 0 0 0 3px rgba(179, 95, 122, 0.25);
        }
        .top-bar input[type="number"] {
            width: 70px;
            border-radius: 40px;
            padding: 6px 8px;
            border: 1px solid #dbaebd;
            text-align: center;
            background: white;
            font-size: 0.9rem;
        }
        .top-bar button {
            background: #b35f7a;
            border: none;
            color: white;
            font-weight: 600;
            padding: 8px 24px;
            border-radius: 60px;
            font-size: 0.9rem;
            cursor: pointer;
            transition: 0.15s;
            box-shadow: 0 4px 8px rgba(150, 60, 90, 0.2);
            border: 1px solid #a04d68;
        }
        .top-bar button:hover {
            background: #9e4b66;
            transform: scale(0.96);
        }
        .month-nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #ffffffdd;
            padding: 8px 16px 8px 22px;
            border-radius: 60px;
            margin: 8px 0 16px;
            border: 1px solid #f0cedb;
            backdrop-filter: blur(4px);
        }
        .month-nav .month-label {
            font-weight: 650;
            font-size: 1.3rem;
            color: #4d2637;
            letter-spacing: 0.3px;
        }
        .month-nav .nav-btn {
            background: #f1dae3;
            border: none;
            border-radius: 40px;
            width: 44px;
            height: 44px;
            font-size: 1.4rem;
            cursor: pointer;
            transition: 0.15s;
            color: #532d3e;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 300;
            border: 1px solid #e7c0ce;
        }
        .month-nav .nav-btn:hover {
            background: #dbb6c6;
            transform: scale(0.94);
        }
        .cycle-info {
            display: flex;
            justify-content: space-between;
            background: #ffffffcc;
            padding: 12px 18px;
            border-radius: 60px;
            margin: 6px 0 18px;
            border: 1px solid #f2cfdb;
            flex-wrap: wrap;
            gap: 6px 14px;
        }
        .cycle-info span {
            font-weight: 500;
            color: #451f2d;
        }
        .cycle-info .badge {
            background: #d9b0bf;
            padding: 2px 18px;
            border-radius: 40px;
            color: #2d1420;
            font-weight: 600;
        }
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            gap: 6px;
            margin-top: 8px;
        }
        .day-cell {
            background: #fffbfc;
            border-radius: 40px;
            aspect-ratio: 1 / 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            font-weight: 500;
            color: #382229;
            border: 1px solid #fad8e2;
            transition: 0.1s ease;
            box-shadow: 0 2px 6px rgba(190, 120, 140, 0.08);
            position: relative;
            padding: 2px;
            line-height: 1.2;
        }
        .day-cell .day-number {
            font-size: 1rem;
            font-weight: 600;
        }
        .day-cell .day-label {
            font-size: 0.5rem;
            text-transform: uppercase;
            opacity: 0.85;
            letter-spacing: 0.2px;
            background: rgba(255,240,245,0.6);
            padding: 1px 8px;
            border-radius: 30px;
            margin-top: 1px;
            white-space: nowrap;
        }
        .day-cell.period {
            background: #f8d0db;
            border-color: #c77a94;
            color: #541f31;
            font-weight: 600;
            box-shadow: inset 0 0 0 1px #d99bb0;
        }
        .day-cell.ovulation {
            background: #d4e9d9;
            border-color: #69a583;
            color: #124d32;
        }
        .day-cell.fertile {
            background: #f5e8c7;
            border-color: #d8b87a;
            color: #624d1f;
        }
        .day-cell.today {
            outline: 3px solid #b35f7a;
            outline-offset: -1px;
            border-color: #b35f7a;
            background: #fff0f5;
        }
        .day-cell.weekend {
            color: #a05f72;
        }
        .day-cell.empty {
            background: transparent;
            border: 1px solid transparent;
            box-shadow: none;
        }
        .legend {
            display: flex;
            flex-wrap: wrap;
            gap: 16px 28px;
            justify-content: center;
            margin: 22px 0 6px;
            padding: 12px 16px;
            background: #ffeef2;
            border-radius: 60px;
            border: 1px solid #fad0db;
        }
        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            color: #40232f;
        }
        .legend-swatch {
            width: 20px;
            height: 20px;
            border-radius: 30px;
            border: 1px solid #ccb0bb;
        }
        .footer-note {
            margin-top: 18px;
            font-size: 0.75rem;
            text-align: center;
            color: #7e5568;
            letter-spacing: 0.2px;
            border-top: 1px solid #f0cedb;
            padding-top: 16px;
            display: flex;
            justify-content: center;
            gap: 20px;
            flex-wrap: wrap;
        }
        .footer-note .moscow-time {
            background: #ecd6df;
            padding: 2px 16px;
            border-radius: 40px;
            font-weight: 500;
        }
        @media (max-width: 500px) {
            .card { padding: 16px 12px; }
            .top-bar { flex-direction: column; align-items: stretch; }
            .month-nav .month-label { font-size: 1.1rem; }
            .day-cell .day-label { font-size: 0.45rem; }
        }
    </style>
</head>
<body>
<div class="card">
    <h1>
        🌸 Календарь
        <small>месячные · PRO</small>
    </h1>

    <div class="top-bar">
        <label>📅 Последние
            <input type="date" id="lastPeriodInput" value="2026-07-01">
        </label>
        <label>🔄 Цикл
            <input type="number" id="cycleLengthInput" value="28" min="21" max="45">
        </label>
        <button id="updateBtn">Обновить</button>
        <span style="margin-left:auto; font-size:0.8rem; background:#f4dee7; padding:2px 14px; border-radius:40px;">⏱️ MSK</span>
    </div>

    <!-- Навигация по месяцам -->
    <div class="month-nav">
        <button class="nav-btn" id="prevMonthBtn">◀</button>
        <span class="month-label" id="monthLabel">Июль 2026</span>
        <button class="nav-btn" id="nextMonthBtn">▶</button>
    </div>

    <div class="cycle-info" id="cycleInfo">
        <span>📆 День цикла: <strong id="cycleDayDisplay">—</strong></span>
        <span>🩸 Следующие: <strong id="nextPeriodDisplay">—</strong></span>
        <span class="badge" id="phaseDisplay">🌱 фаза</span>
    </div>

    <div class="calendar-grid" id="calendarGrid"></div>

    <div class="legend">
        <span class="legend-item"><span class="legend-swatch" style="background:#f8d0db; border-color:#c77a94;"></span> Менструация</span>
        <span class="legend-item"><span class="legend-swatch" style="background:#d4e9d9; border-color:#69a583;"></span> Овуляция</span>
        <span class="legend-item"><span class="legend-swatch" style="background:#f5e8c7; border-color:#d8b87a;"></span> Фертильный</span>
        <span class="legend-item"><span class="legend-swatch" style="background:#fff0f5; outline:2px solid #b35f7a;"></span> Сегодня</span>
    </div>

    <div class="footer-note">
        <span>📌 Клик по дню → установить начало месячных</span>
        <span class="moscow-time" id="moscowTimeDisplay">🕒 МСК: загрузка...</span>
    </div>
</div>

<script>
    (function() {
        // ----- DOM refs -----
        const grid = document.getElementById('calendarGrid');
        const lastPeriodInput = document.getElementById('lastPeriodInput');
        const cycleLengthInput = document.getElementById('cycleLengthInput');
        const updateBtn = document.getElementById('updateBtn');
        const cycleDayDisplay = document.getElementById('cycleDayDisplay');
        const nextPeriodDisplay = document.getElementById('nextPeriodDisplay');
        const phaseDisplay = document.getElementById('phaseDisplay');
        const monthLabel = document.getElementById('monthLabel');
        const prevMonthBtn = document.getElementById('prevMonthBtn');
        const nextMonthBtn = document.getElementById('nextMonthBtn');
        const moscowTimeDisplay = document.getElementById('moscowTimeDisplay');

        // ----- state -----
        let lastPeriod = new Date(2026, 6, 1);
        let cycleLength = 28;
        // Отображаемый месяц (год, месяц)
        let viewYear = 2026;
        let viewMonth = 6; // 0-based (июль)

        // ----- вспомогательные -----
        function getMoscowNow() {
            const now = new Date();
            // смещение московского времени UTC+3
            const mskOffset = 3 * 60; // минут
            const localOffset = now.getTimezoneOffset(); // минут (отрицательно для +)
            const diff = mskOffset + localOffset; // разница в минутах
            const mskTime = new Date(now.getTime() + diff * 60000);
            return mskTime;
        }

        function getTodayMsk() {
            const msk = getMoscowNow();
            return new Date(msk.getFullYear(), msk.getMonth(), msk.getDate());
        }

        // синхронизация lastPeriod из input
        function syncLastPeriodFromInput() {
            const val = lastPeriodInput.value;
            if (!val) return;
            const parts = val.split('-');
            if (parts.length === 3) {
                const y = parseInt(parts[0], 10);
                const m = parseInt(parts[1], 10) - 1;
                const d = parseInt(parts[2], 10);
                if (!isNaN(y) && !isNaN(m) && !isNaN(d)) {
                    lastPeriod = new Date(y, m, d);
                    lastPeriod.setHours(0,0,0,0);
                }
            }
        }

        function syncCycleFromInput() {
            let cl = parseInt(cycleLengthInput.value, 10);
            if (isNaN(cl) || cl < 21) cl = 21;
            if (cl > 45) cl = 45;
            cycleLength = cl;
            cycleLengthInput.value = cl;
        }

        function initFromInputs() {
            syncLastPeriodFromInput();
            syncCycleFromInput();
        }

        // ----- вычисления -----
        function getCycleDay(date) {
            const diff = Math.floor((date - lastPeriod) / (1000 * 60 * 60 * 24));
            return (diff % cycleLength) + 1;
        }

        function getNextPeriodStart(fromDate) {
            const daysSinceLast = Math.floor((fromDate - lastPeriod) / (1000 * 60 * 60 * 24));
            let daysToNext = cycleLength - (daysSinceLast % cycleLength);
            if (daysToNext === 0) daysToNext = cycleLength;
            const next = new Date(fromDate);
            next.setDate(fromDate.getDate() + daysToNext);
            return next;
        }

        function getPhase(dayOfCycle) {
            if (dayOfCycle >= 1 && dayOfCycle <= 5) return 'menstruation';
            if (dayOfCycle >= 12 && dayOfCycle <= 16) return 'ovulation';
            if (dayOfCycle >= 8 && dayOfCycle <= 19) return 'fertile';
            return 'normal';
        }

        function getPhaseText(phase) {
            if (phase === 'menstruation') return '🩸 Месячные';
            if (phase === 'ovulation') return '🥚 Овуляция';
            if (phase === 'fertile') return '🌸 Фертильный';
            return '🌱 Фолликулярная / лютеиновая';
        }

        // ----- рендер календаря для viewMonth/viewYear -----
        function renderCalendar() {
            initFromInputs();

            const todayMsk = getTodayMsk();
            const year = viewYear;
            const month = viewMonth;

            const firstDayOfMonth = new Date(year, month, 1);
            const lastDayOfMonth = new Date(year, month + 1, 0);
            const daysInMonth = lastDayOfMonth.getDate();
            let startDayOfWeek = firstDayOfMonth.getDay(); // 0 вс

            const weekDays = ['Вс', 'Пн', 'Вт', 'Ср', 'Чт', 'Пт', 'Сб'];

            // обновим заголовок месяца
            const monthNames = ['Январь','Февраль','Март','Апрель','Май','Июнь','Июль','Август','Сентябрь','Октябрь','Ноябрь','Декабрь'];
            monthLabel.textContent = `${monthNames[month]} ${year}`;

            let html = '';
            for (let wd of weekDays) {
                html += `<div class="day-cell" style="background:transparent; border:none; font-weight:600; color:#7a4b5c; font-size:0.7rem; aspect-ratio:auto; padding:4px 0;">${wd}</div>`;
            }

            for (let i = 0; i < startDayOfWeek; i++) {
                html += `<div class="day-cell empty"></div>`;
            }

            for (let d = 1; d <= daysInMonth; d++) {
                const currentDate = new Date(year, month, d);
                currentDate.setHours(0,0,0,0);
                const dayOfCycle = getCycleDay(currentDate);
                const phase = getPhase(dayOfCycle);

                let classes = 'day-cell';
                if (phase === 'menstruation') classes += ' period';
                else if (phase === 'ovulation') classes += ' ovulation';
                else if (phase === 'fertile') classes += ' fertile';

                // сегодня (по МСК)
                if (currentDate.getTime() === todayMsk.getTime()) classes += ' today';

                const dow = currentDate.getDay();
                if (dow === 0 || dow === 6) classes += ' weekend';

                let label = '';
                if (phase === 'menstruation') label = '🩸';
                else if (phase === 'ovulation') label = '🥚';
                else if (phase === 'fertile') label = '🌸';

                html += `<div class="${classes}" data-day="${d}" data-month="${month}" data-year="${year}">
                            <span class="day-number">${d}</span>
                            <span class="day-label">${label}</span>
                        </div>`;
            }

            grid.innerHTML = html;

            // ---- обновить информацию ----
            const todayCycleDay = getCycleDay(todayMsk);
            cycleDayDisplay.textContent = todayCycleDay;
            const nextPeriod = getNextPeriodStart(todayMsk);
            const options = { day: 'numeric', month: 'short' };
            nextPeriodDisplay.textContent = nextPeriod.toLocaleDateString('ru-RU', options);
            const phaseToday = getPhase(todayCycleDay);
            phaseDisplay.textContent = getPhaseText(phaseToday);

            // обновим московское время
            updateMoscowTime();
        }

        // ----- время МСК -----
        function updateMoscowTime() {
            const msk = getMoscowNow();
            const hours = String(msk.getHours()).padStart(2, '0');
            const minutes = String(msk.getMinutes()).padStart(2, '0');
            const seconds = String(msk.getSeconds()).padStart(2, '0');
            moscowTimeDisplay.textContent = `🕒 МСК: ${hours}:${minutes}:${seconds}`;
        }

        // ----- навигация по месяцам -----
        function goToMonth(offset) {
            viewMonth += offset;
            if (viewMonth < 0) {
                viewMonth = 11;
                viewYear -= 1;
            } else if (viewMonth > 11) {
                viewMonth = 0;
                viewYear += 1;
            }
            renderCalendar();
        }

        // ----- установка даты начала по клику -----
        function handleDayClick(e) {
            const cell = e.target.closest('.day-cell');
            if (!cell || cell.classList.contains('empty')) return;
            const dayNum = parseInt(cell.dataset.day, 10);
            const month = parseInt(cell.dataset.month, 10);
            const year = parseInt(cell.dataset.year, 10);
            if (isNaN(dayNum) || isNaN(month) || isNaN(year)) return;

            const selectedDate = new Date(year, month, dayNum);
            selectedDate.setHours(0,0,0,0);
            const todayMsk = getTodayMsk();

            // разрешаем только сегодня или прошлое (не будущее)
            if (selectedDate.getTime() > todayMsk.getTime()) {
                alert('Нельзя установить начало в будущем. Выберите сегодня или прошлый день.');
                return;
            }

            lastPeriod = new Date(selectedDate);
            lastPeriod.setHours(0,0,0,0);
            // обновить input
            const y = lastPeriod.getFullYear();
            const m = String(lastPeriod.getMonth() + 1).padStart(2, '0');
            const d = String(lastPeriod.getDate()).padStart(2, '0');
            lastPeriodInput.value = `${y}-${m}-${d}`;
            renderCalendar();
        }

        // ----- обновление по кнопке + полям -----
        function updateFromControls() {
            initFromInputs();
            // синхронизируем view месяц с today? 
            // оставляем 
